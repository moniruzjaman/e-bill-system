# =============================================
# E-Bill System Environment Configuration
# =============================================

# ---------------------------------------------
# LOCAL DEVELOPMENT (SQLite)
# ---------------------------------------------
# For local development, use SQLite:
DATABASE_URL="file:./dev.db"

# ---------------------------------------------
# PRODUCTION (PostgreSQL for Vercel/Railway/etc)
# ---------------------------------------------
# For production, use PostgreSQL with connection pooling:

# Prisma connection pooling URL (used for queries)
# DATABASE_URL="postgresql://username:password@host:5432/e_bill_system?pgbouncer=true&connect_timeout=15"

# Direct database URL (used for migrations)
# DIRECT_DATABASE_URL="postgresql://username:password@host:5432/e_bill_system"

# ---------------------------------------------
# DATABASE PROVIDERS
# ---------------------------------------------
# Vercel Postgres: Copy connection strings from Vercel Dashboard > Storage
# Supabase: Project Settings > Database > Connection string
# Neon: Dashboard > Connection Details
# Railway: Project > Variables tab
# PlanetScale: Settings > Connect > Connect with > Prisma
